<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<manifest>
  <control namespace="LiminityControls" constructor="GoogleAddressAutocomplete" version="1.2.0" display-name-key="GoogleAddressAutocomplete" description-key="Google Address Autocomplete Control" control-type="standard" api-version="1.3.15">
    <property name="address" display-name-key="Address" description-key="Full address" of-type="SingleLine.Text" usage="bound" required="true"/>
    <property name="houseNumber" display-name-key="House Number" description-key="House/Street number" of-type="SingleLine.Text" usage="bound" required="false"/>
    <property name="street" display-name-key="Street" description-key="Street name (without number)" of-type="SingleLine.Text" usage="bound" required="false"/>
    <property name="city" display-name-key="City" description-key="City" of-type="SingleLine.Text" usage="bound" required="false"/>
    <property name="state" display-name-key="State" description-key="State/Province" of-type="SingleLine.Text" usage="bound" required="false"/>
    <property name="postalCode" display-name-key="Postal Code" description-key="Postal/Zip Code" of-type="SingleLine.Text" usage="bound" required="false"/>
    <property name="country" display-name-key="Country" description-key="Country" of-type="SingleLine.Text" usage="bound" required="false"/>
