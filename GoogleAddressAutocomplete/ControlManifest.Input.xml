<?xml version="1.0" encoding="utf-8"?>
<manifest>
  <control namespace="LiminityControls" constructor="GoogleAddressAutocomplete" version="2.0.0" display-name-key="GoogleAddressAutocomplete" description-key="Google Address Autocomplete Control" control-type="standard">
    <property name="address" display-name-key="Address" description-key="Full address" of-type="SingleLine.Text" usage="bound" required="true" />
    <property name="houseNumber" display-name-key="House Number" description-key="House/Street number" of-type="SingleLine.Text" usage="bound" required="false" />
    <property name="street" display-name-key="Street" description-key="Street name (without number)" of-type="SingleLine.Text" usage="bound" required="false" />
    <property name="street2" display-name-key="Street 2" description-key="Unit / apartment / suite (subpremise)" of-type="SingleLine.Text" usage="bound" required="false" />
    <property name="street3" display-name-key="Street 3" description-key="Building / neighborhood / sublocality" of-type="SingleLine.Text" usage="bound" required="false" />
    <property name="streetCombined" display-name-key="Street (Combined)" description-key="Full street line: house number, street, and all additional street parts merged into one field" of-type="SingleLine.Text" usage="bound" required="false" />
    <property name="streetCombinedNoNumber" display-name-key="Street (Combined, No Number)" description-key="Street line without the house number: street and all additional street parts merged into one field" of-type="SingleLine.Text" usage="bound" required="false" />
    <property name="city" display-name-key="City" description-key="City" of-type="SingleLine.Text" usage="bound" required="false" />
    <property name="state" display-name-key="State" description-key="State/Province" of-type="SingleLine.Text" usage="bound" required="false" />
    <property name="postalCode" display-name-key="Postal Code" description-key="Postal/Zip Code" of-type="SingleLine.Text" usage="bound" required="false" />
    <property name="country" display-name-key="Country" description-key="Country" of-type="SingleLine.Text" usage="bound" required="false" />
    <property name="countryCode" display-name-key="Country Code" description-key="Country ISO 3166-1 alpha-2 code (e.g. IN, FR)" of-type="SingleLine.Text" usage="bound" required="false" />
    <property name="apiKeyEnvVariableName" display-name-key="API Key Environment Variable" description-key="Schema name of the Environment Variable that holds the Google Maps API key (e.g. limn_GoogleMapsApiKey). Resolved at runtime: current value first, then the definition default." of-type="SingleLine.Text" usage="input" required="false" />
    <property name="apiKey" display-name-key="API Key (fallback)" description-key="Optional literal Google Maps API key. Used only if the environment variable is not set/resolvable. Prefer the environment variable input." of-type="SingleLine.Text" usage="input" required="false" />
    <property name="placeholder" display-name-key="Placeholder" description-key="Placeholder text for the input" of-type="SingleLine.Text" usage="input" required="false" />
    <property name="countryRestriction" display-name-key="Country Restriction" description-key="Limit results to a specific country (comma-separated country codes)" of-type="SingleLine.Text" usage="input" required="false" />
    <property name="latitude" display-name-key="Latitude" description-key="Latitude coordinate" of-type-group="coordinate" usage="bound" required="false" />
    <property name="longitude" display-name-key="Longitude" description-key="Longitude coordinate" of-type-group="coordinate" usage="bound" required="false" />
    <type-group name="coordinate">
      <type>FP</type>
      <type>Decimal</type>
      <type>Currency</type>
    </type-group>
    <resources>
      <code path="index.ts" order="1"/>
    </resources>
    <feature-usage>
      <uses-feature name="WebAPI" required="true" />
    </feature-usage>
  </control>
</manifest>
